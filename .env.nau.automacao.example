FORMACAO_COLLECTION=formacao
NAU_LOGS_COLLECTION=automacao_nau
NAU_TIME_ZONE=Europe/Lisbon
NAU_DIRECT_FETCH=true
TRIGGER_AMP_AFTER_RUN=true
